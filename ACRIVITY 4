<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Activity 4 - Media Elements</title>
</head>
<body>

<!-- ACTIVITY #4: HTML IMAGE, FAVICON AND AUDIO -->
<section class="activity-section" id="media">

<link rel="icon" href="assets/favicon.ico">

<div class="media-card">
    <h2>🖼️ Activity 4: Media Elements</h2>
    <p>Images • Audio • Favicon Integration</p>

    <div class="media">
        <img src="https://i.pinimg.com/736x/a5/c8/1d/a5c81d6cb0981e0fd2fabecf1eba949f.jpg">
        <img src="https://i.pinimg.com/736x/e2/9d/9f/e29d9f483bd20a358ce85bc5d9a83e17.jpg">

        <!-- FIXED: Counting Stars Audio with Autoplay -->
        <audio controls autoplay loop>
            <source src="audio/counting-stars.mp3" type="audio/mpeg">
            <!-- Fallback for browsers that don't support MP3 -->
            <source src="audio/counting-stars.ogg" type="audio/ogg">
            Your browser does not support the audio element.
        </audio>
    </div>

    <span>⭐ Media assets integrated - Counting Stars by OneRepublic 🎵</span>
</div>

</section>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.activity-section{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;

    /* OneRepublic Background */
    background:url("https://onerepublic.com/cdn/shop/files/1R_NYL_FINAL-Web.jpg?v=1773783606&width=2000")
    center/cover no-repeat fixed;

    position:relative;
    overflow:hidden;
    padding:40px;
}

/* Dark overlay for readability */
.activity-section::before{
    content:"";
    position:absolute;
    inset:0;
    background:rgba(0,0,0,.6);
    z-index: 1;
}

/* Glow effect */
.activity-section::after{
    content:"";
    position:absolute;
    width:250px;
    height:250px;
    border-radius:50%;
    background:rgba(255,255,255,.12);
    filter:blur(60px);
    top:-60px;
    left:-60px;
    z-index: 1;
    animation: float 6s ease-in-out infinite;
}

@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
}

.media-card{
    position:relative;
    z-index:2;
    width:90%;
    max-width:750px;
    padding:45px;
    text-align:center;
    color:#fff;

    background:rgba(0,0,0,.45);
    backdrop-filter:blur(18px);
    border:1px solid rgba(255,255,255,.2);
    border-radius:25px;
    box-shadow:0 25px 60px rgba(0,0,0,.5);
    transition:.3s ease;
}

.media-card:hover{
    transform:translateY(-8px) scale(1.02);
    box-shadow:0 35px 80px rgba(0,0,0,.6);
}

.media{
    margin-top:20px;
    display:flex;
    justify-content:center;
    gap:15px;
    flex-wrap:wrap;
}

.media img{
    width:180px;
    height:130px;
    object-fit:cover;
    border-radius:15px;
    transition:.3s ease;
    border:2px solid rgba(255,255,255,.3);
    cursor: pointer;
}

.media img:hover{
    transform:scale(1.08) rotate(1deg);
    box-shadow:0 15px 30px rgba(0,0,0,.4);
    border-color: rgba(255,255,255,.6);
}

audio{
    width:100%;
    max-width:300px;
    margin-top:15px;
    filter: hue-rotate(200deg) brightness(1.2) saturate(1.3);
    border-radius: 12px;
}

/* Music playing animation */
@keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); }
}

audio[playing] {
    animation: pulse 1.5s infinite;
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.5);
}

h2{
    font-size:2.2rem;
    margin-bottom:10px;
    background: linear-gradient(45deg, #fff, #a8e6cf);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

p{
    opacity:.9;
    margin-bottom:25px;
    font-size: 1.1rem;
}

span {
    display: block;
    margin-top: 20px;
    padding: 12px 24px;
    background: rgba(59, 130, 246, 0.2);
    border: 1px solid rgba(59, 130, 246, 0.4);
    border-radius: 25px;
    font-weight: 500;
    animation: glow 2s ease-in-out infinite alternate;
}

@keyframes glow {
    from { box-shadow: 0 0 10px rgba(59, 130, 246, 0.3); }
    to { box-shadow: 0 0 20px rgba(59, 130, 246, 0.6); }
}

/* Responsive */
@media (max-width: 768px) {
    .activity-section {
        padding: 20px;
    }
    
    .media-card {
        padding: 30px 20px;
        width: 95%;
    }
    
    h2 {
        font-size: 1.8rem;
    }
    
    .media img {
        width: 140px;
        height: 100px;
    }
}
</style>

<script>
// 🎵 Enhanced Audio Controls for Counting Stars
document.addEventListener('DOMContentLoaded', function() {
    const audio = document.querySelector('audio');
    const statusSpan = document.querySelector('span');
    
    // Try to autoplay
    const playAudio = () => {
        audio.play().then(() => {
            console.log('🎵 Counting Stars by OneRepublic is now playing!');
            audio.setAttribute('playing', 'true');
            statusSpan.textContent = '⭐ Counting Stars by OneRepublic - NOW PLAYING 🎵';
        }).catch(e => {
            console.log('Autoplay blocked - user interaction required');
            statusSpan.textContent = '⭐ Click play to hear Counting Stars by OneRepublic 🎵';
        });
    };
    
    // Initial autoplay attempt
    playAudio();
    
    // Event listeners
    audio.addEventListener('play', () => {
        audio.setAttribute('playing', 'true');
        statusSpan.textContent = '⭐ Counting Stars by OneRepublic - NOW PLAYING 🎵';
    });
    
    audio.addEventListener('pause', () => {
        audio.removeAttribute('playing');
        statusSpan.textContent = '⭐ Paused - Click play for Counting Stars 🎵';
    });
    
    audio.addEventListener('ended', () => {
        audio.removeAttribute('playing');
        statusSpan.textContent = '⭐ Finished - Click play for Counting Stars 🎵';
    });
    
    // Click anywhere to play (helps with autoplay policies)
    document.addEventListener('click', function(e) {
        if (audio.paused && !audio.ended) {
            playAudio();
        }
    }, { once: true });
    
    // Image click animations
    document.querySelectorAll('.media img').forEach(img => {
        img.addEventListener('click', function() {
            this.style.transform = 'scale(0.95) rotate(-2deg)';
            setTimeout(() => {
                this.style.transform = '';
            }, 150);
        });
    });
});
</script>

</body>
</html>
